[Unit]
Description=Video Folder Merger
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/video-folder-merger
ExecStart=/opt/video-folder-merger/venv/bin/python /opt/video-folder-merger/video_folder_merger.py
Restart=always
RestartSec=10
User=root

[Install]
WantedBy=multi-user.target
